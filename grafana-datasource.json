{
  "apiVersion": 1,
  "providers": [
    {
      "name": "Prometheus",
      "type": "file",
      "options": {
        "path": "/etc/grafana/provisioning/datasources"
      }
    }
  ],
  "datasources": [
    {
      "name": "Prometheus",
      "type": "prometheus",
      "access": "proxy",
      "url": "http://prometheus:9090",
      "jsonData": {
        "timeInterval": "15s"
      },
      "isDefault": true,
      "editable": true
    }
  ]
}
