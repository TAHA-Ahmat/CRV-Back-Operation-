# Staging Environment
NODE_ENV=staging
PORT=3000

# Database
MONGODB_URI=mongodb://admin:staging-password@mongodb:27017/crv-staging

# Security
JWT_SECRET=your-jwt-secret-here

# Monitoring
SENTRY_DSN=your-sentry-dsn-here

# IA Agents
ANTHROPIC_API_KEY=your-anthropic-key-here

# Vault (optional for staging)
VAULT_ADDR=http://vault:8200
VAULT_TOKEN=your-vault-token-here
